import { google } from 'googleapis'

const SPREADSHEET_ID = process.env.GOOGLE_SPREADSHEET_ID || ''

// Initialize Google Sheets API
function getGoogleSheetsClient() {
  const auth = new google.auth.GoogleAuth({
    credentials: {
      client_email: process.env.GOOGLE_SHEETS_CLIENT_EMAIL,
      private_key: process.env.GOOGLE_SHEETS_PRIVATE_KEY?.replace(/\\n/g, '\n'),
    },
    scopes: ['https://www.googleapis.com/auth/spreadsheets'],
  })

  return google.sheets({ version: 'v4', auth })
}

export async function syncToGoogleSheets(
  sheetName: string,
  data: any[],
  action: 'insert' | 'update' | 'delete'
) {
  try {
    const sheets = getGoogleSheetsClient()

    if (action === 'insert') {
      await sheets.spreadsheets.values.append({
        spreadsheetId: SPREADSHEET_ID,
        range: `${sheetName}!A:Z`,
        valueInputOption: 'USER_ENTERED',
        requestBody: {
          values: data,
        },
      })
    } else if (action === 'update') {
      await sheets.spreadsheets.values.update({
        spreadsheetId: SPREADSHEET_ID,
        range: `${sheetName}!A:Z`,
        valueInputOption: 'USER_ENTERED',
        requestBody: {
          values: data,
        },
      })
    }

    return { success: true }
  } catch (error: any) {
    console.error('Google Sheets sync error:', error)
    return { success: false, error: error.message }
  }
}

export async function saveBookingToSheets(booking: any) {
  const row = [
    booking.booking_id,
    booking.customer_name,
    booking.mobile_number,
    booking.service_name,
    booking.appointment_date,
    booking.appointment_time,
    booking.total_amount,
    booking.booking_status,
    booking.payment_status,
    new Date().toISOString(),
  ]

  return await syncToGoogleSheets('Bookings', [row], 'insert')
}

export async function saveCustomerToSheets(customer: any) {
  const row = [
    customer.customer_id,
    customer.full_name,
    customer.mobile_number,
    customer.email || '',
    customer.date_of_birth || '',
    customer.city || '',
    customer.member_since,
    customer.total_visits,
    customer.total_spent,
    new Date().toISOString(),
  ]

  return await syncToGoogleSheets('Customers', [row], 'insert')
}

